{{- if .Config.Sections.Outputs -}}
    {{- if not .Module.Outputs -}}
        {{- if not .Config.Settings.HideEmpty -}}
            {{- indent 0 "#" }} Outputs{{ if .Config.Settings.AtxClosed }} {{ indent 0 "#" }}{{ end }}

            No outputs.
        {{ end }}
    {{ else }}
        {{- indent 0 "#" }} Outputs{{ if .Config.Settings.AtxClosed }} {{ indent 0 "#" }}{{ end }}

        | Name | Description |{{ if .Config.OutputValues.Enabled }} Value |{{ if $.Config.Settings.Sensitive }} Sensitive |{{ end }}{{ end }}
        | ---- | ----------- |{{ if .Config.OutputValues.Enabled }} ----- |{{ if $.Config.Settings.Sensitive }} :-------: |{{ end }}{{ end }}
        {{- range .Module.Outputs }}
            | {{ anchorNameMarkdown "output" .Name }}{{ if and $.Config.Settings.Deprecated .IsDeprecated }}[^{{ .Name }}_deprecated]{{ end }} | {{ tostring .Description | sanitizeMarkdownTbl }} |
            {{- if $.Config.OutputValues.Enabled -}}
                {{- $sensitive := ternary .Sensitive "<sensitive>" .GetValue -}}
                {{ printf " " }}{{ value $sensitive | sanitizeMarkdownTbl }} |
                {{- if $.Config.Settings.Sensitive -}}
                    {{ printf " " }}{{ ternary .Sensitive "yes" "no" }} |
                {{- end -}}
            {{- end -}}
        {{- end }}
        {{- if $.Config.Settings.Deprecated }}
            {{- range .Module.Outputs }}
                {{- if .IsDeprecated }}

[^{{ .Name }}_deprecated]: **Deprecated** — {{ tostring .Deprecated | sanitizeMarkdownTbl }}
                {{- end -}}
            {{- end }}
        {{- end }}
    {{ end }}
{{ end -}}